# Copy this file to `.env` and fill in your real values. `.env` is git-ignored.

# Anthropic API key — powers the real language layer (createAnthropicLlm).
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (Phase 3 wiring). From your project's Settings -> API page.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Server-side only — bypasses Row Level Security. Never ship this to the app.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# A Supabase Auth user you create (Authentication -> Users -> Add user), used
# for headless persistence tests / the backend re-plan job.
TEST_USER_EMAIL=you@example.com
TEST_USER_PASSWORD=your-test-password
